#!/usr/bin/env python3
"""Example post-reserve hook.

This script runs automatically after a pod becomes ready.
Place your version at: ~/.gpu-dev/hooks/post-reserve

Use it to inject credentials, mount storage, or run any
environment-specific setup on the pod.

No kubectl needed — uses the same gpu_dev_cli K8s client.

Available environment variables:
    GPU_DEV_POD_NAME        - Pod name (e.g. gpu-dev-abc12345)
    GPU_DEV_NAMESPACE       - K8s namespace (e.g. gpu-dev)
    GPU_DEV_RESERVATION_ID  - Full reservation ID
    GPU_DEV_NODE_IP         - Node IP address
    GPU_DEV_SSH_PORT        - SSH NodePort
    GPU_DEV_USERNAME        - Username inside the pod
"""
import base64
import os
from pathlib import Path


def main():
    pod_name = os.environ.get("GPU_DEV_POD_NAME")
    namespace = os.environ.get("GPU_DEV_NAMESPACE", "gpu-dev")
    if not pod_name:
        return

    from gpu_dev_cli.config import load_config
    from gpu_dev_cli.k8s_direct import K8sDirectManager
    from kubernetes.stream import stream

    mgr = K8sDirectManager(load_config())

    def exec_in_pod(cmd):
        return stream(
            mgr.v1.connect_get_namespaced_pod_exec,
            pod_name, namespace,
            command=["/bin/sh", "-c", cmd],
            container="dev",
            stderr=True, stdout=True, stdin=False, tty=False,
        )

    def inject_file(local_path, pod_path, mode="644"):
        """Copy a local file into the pod via base64 encoding."""
        local = Path(local_path)
        if not local.exists():
            return False
        content_b64 = base64.b64encode(local.read_bytes()).decode()
        pod_dir = str(Path(pod_path).parent)
        exec_in_pod(
            f"mkdir -p '{pod_dir}' && "
            f"echo '{content_b64}' | base64 -d > '{pod_path}' && "
            f"chmod {mode} '{pod_path}'"
        )
        return True

    # Example: inject a CA cert
    # inject_file("/path/to/ca.pem", "/etc/ssl/custom/ca.pem")

    print(f"Post-reserve hook for pod {pod_name}")


if __name__ == "__main__":
    main()
